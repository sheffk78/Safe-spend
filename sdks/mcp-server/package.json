{
  "name": "@safespend/mcp-server",
  "version": "0.1.0",
  "description": "MCP Server for Safe-Spend API - enables AI agents to interact with escrow and spending controls",
  "main": "./dist/index.js",
  "bin": {
    "safespend-mcp": "./dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts src/client.ts --format esm --clean --no-dts",
    "dev": "tsup src/index.ts src/client.ts --format esm --watch",
    "start": "node dist/index.js",
    "inspect": "npx @modelcontextprotocol/inspector dist/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "safe-spend",
    "safespend",
    "escrow",
    "ai-agents",
    "claude",
    "agentic-trust"
  ],
  "author": {
    "name": "Agentic Trust",
    "email": "support@agentictrust.app"
  },
  "license": "Proprietary",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentictrust/safespend-mcp-server"
  },
  "homepage": "https://agentictrust.app",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.5.1",
    "typescript": "^5.3.3"
  }
}

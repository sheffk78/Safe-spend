// This is your Prisma schema file for Safe-Spend
// PostgreSQL Production Configuration
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Admin Users (for internal Agentic Trust operators)
model AdminUser {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         String   @default("support") // superadmin | support | read_only
  name         String?
  isActive     Boolean  @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("admin_users")
}

// Organizations (users/companies)
model Organization {
  id                String   @id @default(uuid())
  name              String
  email             String   @unique
  passwordHash      String   @map("password_hash")
  stripeCustomerId  String?  @map("stripe_customer_id")
  plan              String   @default("sandbox") // sandbox | builder | scale
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  apiKeys          ApiKey[]
  escrowAccounts   EscrowAccount[]
  spendingPolicies SpendingPolicy[]
  spendRequests    SpendRequest[]
  approvals        Approval[]
  auditEvents      AuditEvent[]
  webhooks         Webhook[]

  @@map("organizations")
}

// API Keys
model ApiKey {
  id          String    @id @default(uuid())
  orgId       String    @map("org_id")
  keyHash     String    @map("key_hash")
  keyPrefix   String    @map("key_prefix")
  keyType     String    @map("key_type") // live | test | agent
  label       String?
  permissions String    @default("[]")
  lastUsedAt  DateTime? @map("last_used_at")
  isRevoked   Boolean   @default(false) @map("is_revoked")
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  organization  Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  spendRequests SpendRequest[]

  @@map("api_keys")
}

// Escrow Accounts
model EscrowAccount {
  id                    String   @id @default(uuid())
  orgId                 String   @map("org_id")
  name                  String
  description           String?
  balanceCents          Int      @default(0) @map("balance_cents")
  currency              String   @default("usd")
  status                String   @default("active") // active | paused | depleted | closed
  stripePaymentIntentId String?  @map("stripe_payment_intent_id")
  totalFundedCents      Int      @default(0) @map("total_funded_cents")
  totalSpentCents       Int      @default(0) @map("total_spent_cents")
  totalDeniedCents      Int      @default(0) @map("total_denied_cents")
  metadata              String   @default("{}")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  // Relations
  organization     Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  spendingPolicies SpendingPolicy[]
  spendRequests    SpendRequest[]
  auditEvents      AuditEvent[]
  dailyTracking    DailySpendTracking[]
  weeklyTracking   WeeklySpendTracking[]
  monthlyTracking  MonthlySpendTracking[]
  fundingEvents    FundingEvent[]

  @@map("escrow_accounts")
}

// Spending Policies (Rules)
model SpendingPolicy {
  id                        String   @id @default(uuid())
  escrowId                  String   @map("escrow_id")
  orgId                     String   @map("org_id")
  name                      String
  isActive                  Boolean  @default(true) @map("is_active")
  
  // Spending limits
  perTransactionLimitCents  Int?     @map("per_transaction_limit_cents")
  dailyLimitCents           Int?     @map("daily_limit_cents")
  weeklyLimitCents          Int?     @map("weekly_limit_cents")
  monthlyLimitCents         Int?     @map("monthly_limit_cents")
  
  // Vendor controls
  allowedVendors            String   @default("[]") @map("allowed_vendors") // JSON array
  blockedVendors            String   @default("[]") @map("blocked_vendors") // JSON array
  vendorMatchMode           String   @default("exact") @map("vendor_match_mode") // exact | contains | regex
  
  // Category controls
  allowedCategories         String   @default("[]") @map("allowed_categories") // JSON array
  blockedCategories         String   @default("[]") @map("blocked_categories") // JSON array
  
  // Time-based controls
  activeDays                String   @default("[]") @map("active_days") // JSON array of days ["monday", "tuesday", etc]
  activeHoursStart          String?  @map("active_hours_start") // "09:00"
  activeHoursEnd            String?  @map("active_hours_end") // "17:00"
  activeTimezone            String   @default("UTC") @map("active_timezone")
  
  // Approval thresholds
  autoApproveUnderCents     Int?     @map("auto_approve_under_cents")
  requireHumanAboveCents    Int?     @map("require_human_above_cents")
  approvalTimeoutMinutes    Int      @default(60) @map("approval_timeout_minutes")
  
  // Metadata
  metadata                  String   @default("{}")
  priority                  Int      @default(0) // Higher priority evaluated first
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  // Relations
  escrowAccount EscrowAccount @relation(fields: [escrowId], references: [id], onDelete: Cascade)
  organization  Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("spending_policies")
}

// Spend Requests (Transactions)
model SpendRequest {
  id                String   @id @default(uuid())
  escrowId          String   @map("escrow_id")
  orgId             String   @map("org_id")
  apiKeyId          String?  @map("api_key_id")
  amountCents       Int      @map("amount_cents")
  currency          String   @default("usd")
  vendor            String
  category          String?
  description       String?
  idempotencyKey    String?  @map("idempotency_key")
  
  // Status and resolution
  status            String   @default("pending") // approved | denied | pending | expired | cancelled
  resolvedAt        DateTime? @map("resolved_at")
  resolvedBy        String?  @map("resolved_by") // human:<user_id> | system:auto_approved | system:rule_denied | system:timeout
  denialReason      String?  @map("denial_reason")
  denialRuleId      String?  @map("denial_rule_id")
  
  // Audit trail
  rulesEvaluated    String   @default("[]") @map("rules_evaluated") // JSON of rules evaluated
  balanceBeforeCents Int?    @map("balance_before_cents")
  balanceAfterCents Int?     @map("balance_after_cents")
  
  metadata          String   @default("{}")
  createdAt         DateTime @default(now()) @map("created_at")

  // Relations
  escrowAccount EscrowAccount @relation(fields: [escrowId], references: [id], onDelete: Cascade)
  organization  Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  apiKey        ApiKey?       @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  approval      Approval?

  // Ensure idempotency key is unique per org
  @@unique([orgId, idempotencyKey])
  @@map("spend_requests")
}

// Approvals (for human review)
model Approval {
  id              String    @id @default(uuid())
  spendRequestId  String    @unique @map("spend_request_id")
  orgId           String    @map("org_id")
  status          String    @default("pending") // pending | approved | denied | expired
  requestedAt     DateTime  @default(now()) @map("requested_at")
  expiresAt       DateTime  @map("expires_at")
  decidedBy       String?   @map("decided_by")
  decidedAt       DateTime? @map("decided_at")
  decisionNote    String?   @map("decision_note")
  notificationSent Boolean  @default(false) @map("notification_sent")
  
  // Relations
  spendRequest SpendRequest @relation(fields: [spendRequestId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("approvals")
}

// Audit Events
model AuditEvent {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  escrowId    String?  @map("escrow_id")
  eventType   String   @map("event_type") // escrow.created, escrow.funded, spend.approved, etc.
  actorType   String   @map("actor_type") // agent | human | system
  actorId     String?  @map("actor_id")
  details     String   @default("{}") // JSON
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  organization  Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  escrowAccount EscrowAccount? @relation(fields: [escrowId], references: [id], onDelete: SetNull)

  @@index([orgId, createdAt])
  @@index([eventType])
  @@map("audit_events")
}

// Webhooks
model Webhook {
  id              String    @id @default(uuid())
  orgId           String    @map("org_id")
  url             String
  events          String    @default("[]") // JSON array of event types
  secret          String    // For HMAC signing
  isActive        Boolean   @default(true) @map("is_active")
  description     String?
  failureCount    Int       @default(0) @map("failure_count")
  lastTriggeredAt DateTime? @map("last_triggered_at")
  lastFailedAt    DateTime? @map("last_failed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("webhooks")
}

// Daily Spend Tracking (for daily cap enforcement)
model DailySpendTracking {
  id              String   @id @default(uuid())
  escrowId        String   @map("escrow_id")
  date            String   // YYYY-MM-DD format
  totalSpentCents Int      @default(0) @map("total_spent_cents")
  transactionCount Int     @default(0) @map("transaction_count")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  escrowAccount EscrowAccount @relation(fields: [escrowId], references: [id], onDelete: Cascade)

  @@unique([escrowId, date])
  @@map("daily_spend_tracking")
}

// Weekly Spend Tracking
model WeeklySpendTracking {
  id              String   @id @default(uuid())
  escrowId        String   @map("escrow_id")
  weekStart       String   // YYYY-MM-DD (Monday of the week)
  totalSpentCents Int      @default(0) @map("total_spent_cents")
  transactionCount Int     @default(0) @map("transaction_count")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  escrowAccount EscrowAccount @relation(fields: [escrowId], references: [id], onDelete: Cascade)

  @@unique([escrowId, weekStart])
  @@map("weekly_spend_tracking")
}

// Monthly Spend Tracking
model MonthlySpendTracking {
  id              String   @id @default(uuid())
  escrowId        String   @map("escrow_id")
  monthStart      String   // YYYY-MM-01 (First of the month)
  totalSpentCents Int      @default(0) @map("total_spent_cents")
  transactionCount Int     @default(0) @map("transaction_count")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  escrowAccount EscrowAccount @relation(fields: [escrowId], references: [id], onDelete: Cascade)

  @@unique([escrowId, monthStart])
  @@map("monthly_spend_tracking")
}

// Funding Events (for audit trail)
model FundingEvent {
  id                    String   @id @default(uuid())
  escrowId              String   @map("escrow_id")
  amountCents           Int      @map("amount_cents")
  fundingType           String   @map("funding_type") // stripe | manual | refund
  stripePaymentIntentId String?  @map("stripe_payment_intent_id")
  stripeSessionId       String?  @map("stripe_session_id")
  balanceBeforeCents    Int?     @map("balance_before_cents")
  balanceAfterCents     Int?     @map("balance_after_cents")
  metadata              String   @default("{}")
  createdAt             DateTime @default(now()) @map("created_at")

  // Relations
  escrowAccount EscrowAccount @relation(fields: [escrowId], references: [id], onDelete: Cascade)

  @@map("funding_events")
}

// Blog Posts (for AgenticTrust sub-brand content)
model BlogPost {
  id                    String   @id @default(uuid())
  title                 String
  slug                  String   @unique
  content               String
  contentHtml            String   @map("content_html")
  excerpt               String?
  status                String   @default("draft")
  authorName            String   @map("author_name")
  authorBio             String?  @map("author_bio")
  authorAvatarUrl       String?  @map("author_avatar_url")
  coverImageUrl         String?  @map("cover_image_url")
  coverImageAlt         String?  @map("cover_image_alt")
  tags                  String   @default("[]")
  category              String?
  seoMetaTitle           String?  @map("seo_meta_title")
  seoMetaDescription     String?  @map("seo_meta_description")
  seoCanonicalUrl        String?  @map("seo_canonical_url")
  seoOgTitle             String?  @map("seo_og_title")
  seoOgDescription       String?  @map("seo_og_description")
  seoOgImage             String?  @map("seo_og_image")
  seoOgType              String?  @default("article") @map("seo_og_type")
  seoTwitterCard         String?  @default("summary_large_image") @map("seo_twitter_card")
  seoTwitterTitle        String?  @map("seo_twitter_title")
  seoTwitterDescription  String?  @map("seo_twitter_description")
  seoTwitterImage        String?  @map("seo_twitter_image")
  seoKeywords            String?  @map("seo_keywords")
  seoRobots              String?  @default("index, follow") @map("seo_robots")
  seoStructuredData      String?  @map("seo_structured_data")
  readingTimeMinutes     Int      @default(0) @map("reading_time_minutes")
  wordCount              Int      @default(0) @map("word_count")
  views                  Int      @default(0)
  isFeatured             Boolean  @default(false) @map("is_featured")
  relatedPosts           String   @default("[]") @map("related_posts")
  publishedAt            DateTime? @map("published_at")
  scheduledAt            DateTime? @map("scheduled_at")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@map("blog_posts")
}

// Admin API Keys (for Kit automation)
model AdminApiKey {
  id          String    @id @default(uuid())
  label       String    @default("Admin Key")
  description String?
  keyHash     String    @unique @map("key_hash")
  keyPrefix   String    @map("key_prefix")
  scopes      String    @default("[\"*\"]")
  isActive    Boolean   @default(true) @map("is_active")
  lastUsedAt  DateTime? @map("last_used_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  @@map("admin_api_keys")
}

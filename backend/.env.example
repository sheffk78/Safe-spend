# Safe-Spend Environment Variables
# Copy this to .env and fill in your values

# ============================================
# Application
# ============================================
NODE_ENV=development          # development | staging | production
PORT=8001
APP_URL=http://localhost:8001
FRONTEND_URL=http://localhost:3000

# ============================================
# Database
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/safespend

# ============================================
# Authentication
# ============================================
JWT_SECRET=your-very-long-random-secret-here-min-32-chars
JWT_EXPIRES_IN=7d

# ============================================
# Stripe
# ============================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...    # Optional in dev, required in production

# ============================================
# Logging
# ============================================
LOG_LEVEL=info                # debug | info | warn | error

# ============================================
# Rate Limiting (optional overrides)
# ============================================
# RATE_LIMIT_AUTH_MAX=10          # Max auth requests per window
# RATE_LIMIT_AUTH_WINDOW_MS=900000 # 15 minutes
# RATE_LIMIT_SPEND_MAX=60         # Max spend requests per minute
# RATE_LIMIT_GLOBAL_MAX=200       # Global max per minute

# ============================================
# CORS
# ============================================
CORS_ORIGINS=*                # Comma-separated origins or * for dev

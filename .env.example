# Safe-Spend Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# DATABASE (Required)
# ===========================================
# PostgreSQL connection string
DATABASE_URL="postgresql://username:password@host:5432/safespend?schema=public"

# For docker-compose (optional, uses defaults if not set)
POSTGRES_USER=safespend
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=safespend

# ===========================================
# AUTHENTICATION (Required)
# ===========================================
# JWT secret for signing tokens - USE A STRONG RANDOM STRING IN PRODUCTION
JWT_SECRET="generate-a-strong-random-string-at-least-32-chars"

# ===========================================
# CORS (Required)
# ===========================================
# Allowed origins for CORS (comma-separated, or * for all)
CORS_ORIGINS="https://yourdomain.com,https://app.yourdomain.com"

# ===========================================
# STRIPE (Required for payments)
# ===========================================
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ===========================================
# EMAIL (Optional but recommended)
# ===========================================
# Postmark API key for transactional emails
POSTMARK_API_KEY=""
SENDER_EMAIL="no-reply@yourdomain.com"
ALERT_EMAIL="alerts@yourdomain.com"

# ===========================================
# FRONTEND (Required)
# ===========================================
# Backend URL for the frontend to call
REACT_APP_BACKEND_URL="https://api.yourdomain.com"

# ===========================================
# ANALYTICS (Optional)
# ===========================================
# Google Analytics measurement ID
REACT_APP_GA_ID="G-XXXXXXXXXX"

# PostHog project API key
REACT_APP_POSTHOG_KEY="phc_..."
REACT_APP_POSTHOG_HOST="https://app.posthog.com"
